{
  "name": "callflow",
  "version": "0.3.0",
  "description": "Local-first Electron desktop beta app for call-center call logging, hourly reports, reminders, scripts, and shift tracking.",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "check": "node scripts/check-syntax.js",
    "test": "node --test",
    "lint": "eslint src test",
    "validate": "npm run check && npm test && npm run lint",
    "pack:win": "electron-builder --win nsis --dir --x64 --publish never",
    "pack:win:ia32": "electron-builder --win nsis --dir --ia32 --publish never",
    "dist:win": "electron-builder --win nsis --x64 --publish never",
    "dist:win:ia32": "electron-builder --win nsis --ia32 --publish never",
    "dist:win:portable": "electron-builder --win portable --x64 --publish never",
    "dist:win:portable:ia32": "electron-builder --win portable --ia32 --publish never",
    "dist:win:all": "npm run dist:win && npm run dist:win:ia32 && npm run dist:win:portable && npm run dist:win:portable:ia32"
  },
  "keywords": [
    "electron",
    "call-center",
    "crm",
    "desktop"
  ],
  "author": "GaboEI",
  "license": "Apache-2.0",
  "private": true,
  "build": {
    "appId": "com.gaboei.callflow",
    "productName": "CallFlow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.ico",
      "build/icon.png",
      "node_modules/easymde/dist/easymde.min.js",
      "node_modules/easymde/LICENSE",
      "node_modules/dompurify/dist/purify.min.js",
      "node_modules/dompurify/LICENSE",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "selectPerMachineByDefault": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CallFlow",
      "deleteAppDataOnUninstall": false,
      "license": "docs/legal/WINDOWS_INSTALLER_EULA.txt",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "easymde": "^2.21.0"
  }
}
